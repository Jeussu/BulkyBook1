@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="manage-shell mt-4">
    <div class="bb-panel">
        <div class="bb-panel-header">
            <div>
                <p class="text-uppercase small text-muted fw-bold mb-1">Account settings</p>
                <h1 class="h3 bb-panel-title">Manage your account</h1>
            </div>
        </div>
        <div class="manage-grid p-4">
            <aside class="manage-nav-panel">
                <partial name="_ManageNav" />
            </aside>
            <section class="manage-content-panel">
                @RenderBody()
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
