@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-shell auth-shell--login mt-4">
    <div class="row g-4 align-items-stretch">
        <div class="col-12 col-lg-5">
            <section class="auth-aside">
                <p class="auth-kicker">BulkyBook account</p>
                <h1>Welcome back.</h1>
                <p>Sign in to manage your cart, orders, and account.</p>

                <div class="auth-aside-grid">
                    <div>
                        <span>Secure</span>
                        <strong>Identity</strong>
                    </div>
                    <div>
                        <span>Orders</span>
                        <strong>Tracked</strong>
                    </div>
                </div>
            </section>
        </div>
        <div class="col-12 col-lg-7">
            <section class="auth-card">
                <div class="auth-card-header">
                    <span class="auth-kicker">Account access</span>
                    <h2>Log in</h2>
                    <p>Use your BulkyBook account to continue.</p>
                </div>

                <form id="account" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary"></div>
                    <div class="form-floating auth-field">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                        <label asp-for="Input.Email" class="form-label"></label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="form-floating auth-field">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                        <label asp-for="Input.Password" class="form-label"></label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-check auth-remember">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary auth-submit">Log in</button>
                    <div class="auth-link-row">
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create account</a>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend confirmation</a>
                    </div>
                </form>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <hr class="auth-divider" />
                    <div class="auth-external-header">
                        <span class="auth-kicker">External access</span>
                        <h3>External login</h3>
                    </div>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="auth-provider-list">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                var providerName = provider.DisplayName ?? provider.Name;
                                <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name" title="Log in using your @providerName account">@providerName</button>
                            }
                        </div>
                    </form>
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
