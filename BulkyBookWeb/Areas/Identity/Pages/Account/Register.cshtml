@page
@using BulkyBook.Utility
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    var isAdmin = User.IsInRole(SD.Role_Admin);
}

<div class="auth-shell mt-4">
    <div class="row g-4 align-items-stretch">
        <div class="col-12 col-lg-4">
            <section class="auth-aside">
                <p class="text-uppercase small fw-bold mb-2">@(isAdmin ? "Admin portal" : "Reader account")</p>
                <h1 class="display-6 fw-bold mb-3">@(isAdmin ? "Create a user." : "Create your account.")</h1>
                <p class="mb-0">
                    @(isAdmin
                        ? "Assign staff, company, or customer roles for local testing."
                        : "Register as an individual reader and start testing the bookstore flow.")
                </p>
            </section>
        </div>
        <div class="col-12 col-lg-8">
            <section class="auth-card">
                <h2 class="h3 mb-1">@(isAdmin ? "Register user" : "Register")</h2>
                <p class="text-muted mb-4">Fill in the account and shipping profile details.</p>
                <form id="registerForm" class="row g-3" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-floating col-12">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                        <label asp-for="Input.Email"></label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.Name" class="form-control" aria-required="true" />
                        <label asp-for="Input.Name"></label>
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.PhoneNumber" class="form-control" aria-required="true" />
                        <label asp-for="Input.PhoneNumber"></label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.StreetAddress" class="form-control" aria-required="true" />
                        <label asp-for="Input.StreetAddress"></label>
                        <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.City" class="form-control" aria-required="true" />
                        <label asp-for="Input.City"></label>
                        <span asp-validation-for="Input.City" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.State" class="form-control" aria-required="true" />
                        <label asp-for="Input.State"></label>
                        <span asp-validation-for="Input.State" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.PostalCode" class="form-control" aria-required="true" />
                        <label asp-for="Input.PostalCode"></label>
                        <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" />
                        <label asp-for="Input.Password"></label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-floating col-12 col-md-6">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
                        <label asp-for="Input.ConfirmPassword"></label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="form-floating col-12 col-md-6">
                            <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select">
                                <option disabled selected>-Select Role-</option>
                            </select>
                            <label asp-for="Input.Role"></label>
                        </div>
                        <div class="form-floating col-12 col-md-6">
                            <select asp-for="Input.CompanyId" style="display:none;" asp-items="@Model.Input.CompanyList" class="form-select">
                                <option disabled selected>-Select Company-</option>
                            </select>
                            <label asp-for="Input.CompanyId"></label>
                        </div>
                    }
                    <div class="col-12">
                        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
                    </div>
                </form>

                @if (!isAdmin && (Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <hr class="my-4" />
                    <h3 class="h6">External registration</h3>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                var providerName = provider.DisplayName ?? provider.Name;
                                <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name" title="Log in using your @providerName account">@providerName</button>
                            }
                        </div>
                    </form>
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function(){
            $('#Input_Role').change(function(){
                var selection = $('#Input_Role Option:Selected').text();
                if(selection != 'Company'){
                    $('#Input_CompanyId').hide();
                }
                else{
                    $('#Input_CompanyId').show();
                }
            })
        })
    </script>
}
