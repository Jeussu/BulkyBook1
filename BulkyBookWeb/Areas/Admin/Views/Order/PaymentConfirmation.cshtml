@model int

<section class="confirmation-shell confirmation-shell--payment mt-4">
    <div class="confirmation-panel">
        <div class="confirmation-icon confirmation-icon--success" aria-hidden="true">
            <i class="bi bi-check-lg"></i>
        </div>

        <p class="confirmation-kicker">Payment confirmed</p>
        <h1 class="confirmation-title">Payment Successfully!</h1>
        <p class="confirmation-message">
            Payment has been applied successfully for this order.
        </p>

        <div class="confirmation-order">
            <span>Order Number</span>
            <strong>@Model</strong>
        </div>

        <div class="confirmation-actions">
            <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-orderId="@Model" class="btn btn-primary confirmation-primary-action">
                Back to Order Details
            </a>
        </div>
    </div>
</section>

