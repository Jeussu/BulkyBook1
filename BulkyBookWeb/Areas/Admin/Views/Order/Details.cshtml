@model BulkyBook.Models.ViewModels.OrderVm
@using BulkyBook.Utility
@using System.Globalization
@{
    var isStaff = User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee);
    var usdCulture = CultureInfo.GetCultureInfo("en-US");
    Func<double, string> usd = value => value.ToString("C", usdCulture);
    Func<DateTime, string, string> formatDate = (value, emptyText) => value == default ? emptyText : value.ToShortDateString();
}

<form method="post" class="order-shell mt-4">
    @Html.AntiForgeryToken()
    <input asp-for="OrderHeader.Id" hidden />

    <div class="bb-panel">
        <div class="bb-panel-header">
            <div>
                <p class="text-uppercase small text-muted fw-bold mb-1">Order #@Model.OrderHeader.Id</p>
                <h1 class="h3 bb-panel-title">Order Details</h1>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Orders</a>
        </div>

        <div class="p-4 order-detail-grid">
            <section>
                <div class="status-strip mb-4">
                    <span class="badge badge-soft">Order: @Model.OrderHeader.OrderStatus</span>
                    <span class="badge badge-soft">Payment: @Model.OrderHeader.PaymentStatus</span>
                    <span class="badge badge-soft">Ordered: @formatDate(Model.OrderHeader.OrderDate, "Not set")</span>
                </div>

                <h2 class="h5 mb-3">Customer and shipping</h2>
                <div class="row">
                    <div class="col-12 col-md-6 order-field">
                        <label>Name</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.Name" class="form-control" />
                            <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                        }
                        else
                        {
                            <div class="readonly-value">@Model.OrderHeader.Name</div>
                        }
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>Phone</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.PhoneNumber" class="form-control" />
                            <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                        }
                        else
                        {
                            <div class="readonly-value">@Model.OrderHeader.PhoneNumber</div>
                        }
                    </div>
                    <div class="col-12 order-field">
                        <label>Street Address</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.StreetAddress" class="form-control" />
                            <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                        }
                        else
                        {
                            <div class="readonly-value">@Model.OrderHeader.StreetAddress</div>
                        }
                    </div>
                    <div class="col-12 col-md-4 order-field">
                        <label>City</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.City" class="form-control" />
                            <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                        }
                        else
                        {
                            <div class="readonly-value">@Model.OrderHeader.City</div>
                        }
                    </div>
                    <div class="col-12 col-md-4 order-field">
                        <label>State</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.State" class="form-control" />
                            <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                        }
                        else
                        {
                            <div class="readonly-value">@Model.OrderHeader.State</div>
                        }
                    </div>
                    <div class="col-12 col-md-4 order-field">
                        <label>Postal Code</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.PostalCode" class="form-control" />
                            <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                        }
                        else
                        {
                            <div class="readonly-value">@Model.OrderHeader.PostalCode</div>
                        }
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>Email</label>
                        <div class="readonly-value">@Model.OrderHeader.ApplicationUser.Email</div>
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>Shipping Date</label>
                        <div class="readonly-value">@formatDate(Model.OrderHeader.ShippingDate, "Pending")</div>
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>Carrier</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.Carrier" id="carrier" class="form-control" />
                        }
                        else
                        {
                            <div class="readonly-value">@(string.IsNullOrWhiteSpace(Model.OrderHeader.Carrier) ? "Not set" : Model.OrderHeader.Carrier)</div>
                        }
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>Tracking</label>
                        @if (isStaff)
                        {
                            <input asp-for="OrderHeader.TrackingNumber" id="trackingNumber" class="form-control" />
                        }
                        else
                        {
                            <div class="readonly-value">@(string.IsNullOrWhiteSpace(Model.OrderHeader.TrackingNumber) ? "Not set" : Model.OrderHeader.TrackingNumber)</div>
                        }
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>@(Model.OrderHeader.SessionId == null ? "Payment Due Date" : "Payment Date")</label>
                        <div class="readonly-value">
                            @(Model.OrderHeader.SessionId == null
                                ? formatDate(Model.OrderHeader.PaymentDueDate, "Not set")
                                : formatDate(Model.OrderHeader.PaymentDate, "Not set"))
                        </div>
                    </div>
                    <div class="col-12 col-md-6 order-field">
                        <label>Payment Status</label>
                        <div class="readonly-value">@Model.OrderHeader.PaymentStatus</div>
                    </div>
                </div>

                @if (isStaff)
                {
                    <div class="row">
                        <div class="col-12 col-md-6 order-field">
                            <label>Session ID</label>
                            <div class="readonly-value">@(string.IsNullOrWhiteSpace(Model.OrderHeader.SessionId) ? "Not set" : Model.OrderHeader.SessionId)</div>
                        </div>
                        <div class="col-12 col-md-6 order-field">
                            <label>Payment Intent ID</label>
                            <div class="readonly-value">@(string.IsNullOrWhiteSpace(Model.OrderHeader.PaymentIntentId) ? "Not set" : Model.OrderHeader.PaymentIntentId)</div>
                        </div>
                    </div>
                    <button type="submit" asp-action="UpdateOrderDetail" class="btn btn-outline-secondary w-100 mt-2">Update Order Details</button>
                }
            </section>

            <aside>
                <div class="bb-panel order-summary-panel p-3 shadow-none">
                    <h2 class="h5 mb-3">Books in this order</h2>
                    <ul class="list-group mb-3">
                        @foreach (var detail in Model.OrderDetail)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-start">
                                <div>
                                    <h3 class="h6 mb-1">@detail.Product.Title</h3>
                                    <small class="text-muted">@usd(detail.Price) x @detail.Count</small>
                                </div>
                                <strong>@usd(detail.Count * detail.Price)</strong>
                            </li>
                        }
                        <li class="list-group-item px-0 d-flex justify-content-between">
                            <span class="fw-bold">Total</span>
                        <strong class="h5 mb-0">@usd(Model.OrderHeader.OrderTotal)</strong>
                        </li>
                    </ul>

                    <div class="order-action-stack">
                        @if (Model.OrderHeader.PaymentStatus == SD.PaymentStatusDelayedPayment &&
                            Model.OrderHeader.OrderStatus == SD.StatusShipped)
                        {
                            <input type="submit" class="btn btn-success w-100" value="Pay Now" />
                        }

                        @if (isStaff)
                        {
                            if (Model.OrderHeader.OrderStatus == SD.StatusApproved)
                            {
                                <input type="submit" asp-action="StartProcessing" class="btn btn-primary w-100" value="Start Processing" />
                            }
                            if (Model.OrderHeader.OrderStatus == SD.StatusInProcess)
                            {
                                <input type="submit" onclick="return validateInput()" asp-action="ShipOrder" class="btn btn-primary w-100" value="Ship Order" />
                            }
                            if (Model.OrderHeader.OrderStatus != SD.StatusRefunded &&
                                Model.OrderHeader.OrderStatus != SD.StatusCancelled &&
                                Model.OrderHeader.OrderStatus != SD.StatusShipped)
                            {
                                <input type="submit" asp-action="CancelOrder" class="btn btn-danger w-100" value="Cancel Order" />
                            }
                        }
                    </div>
                </div>
            </aside>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function validateInput(){
         if(document.getElementById("trackingNumber").value==""){
             Swal.fire({
               icon: 'error',
               title: 'Missing tracking number',
               text: 'Please enter a tracking number before shipping.'
             });
             return false;
         }
         if(document.getElementById("carrier").value==""){
             Swal.fire({
               icon: 'error',
               title: 'Missing carrier',
               text: 'Please enter a carrier before shipping.'
             });
             return false;
         }
         return true;
     }
    </script>
}
