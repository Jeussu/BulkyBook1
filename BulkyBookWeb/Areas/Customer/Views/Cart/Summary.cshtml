@model BulkyBook.Models.ViewModels.ShoppingCartVM
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment
@using System.Globalization
@{
    var usdCulture = CultureInfo.GetCultureInfo("en-US");
    Func<double, string> usd = value => value.ToString("C", usdCulture);
}

<form method="post" class="checkout-shell mt-4">
    @Html.AntiForgeryToken()
    <div class="bb-panel">
        <div class="bb-panel-header">
            <div>
                <p class="text-uppercase small text-muted fw-bold mb-1">Step 2 of 3</p>
                <h1 class="h3 bb-panel-title">Shipping & Summary</h1>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Cart</a>
        </div>

        <div class="p-4 checkout-grid">
            <section>
                <h2 class="h5 mb-3">Shipping details</h2>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="OrderHeader.Name" class="form-label">Name</label>
                        <input asp-for="OrderHeader.Name" class="form-control" />
                        <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.PhoneNumber" class="form-label">Phone</label>
                        <input asp-for="OrderHeader.PhoneNumber" class="form-control" />
                        <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.PostalCode" class="form-label">Postal Code</label>
                        <input asp-for="OrderHeader.PostalCode" class="form-control" />
                        <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="OrderHeader.StreetAddress" class="form-label">Street Address</label>
                        <input asp-for="OrderHeader.StreetAddress" class="form-control" />
                        <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.City" class="form-label">City</label>
                        <input asp-for="OrderHeader.City" class="form-control" />
                        <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.State" class="form-label">State</label>
                        <input asp-for="OrderHeader.State" class="form-control" />
                        <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <aside>
                <h2 class="h5 mb-3">Order summary</h2>
                <ul class="list-group checkout-summary-list mb-3">
                    @foreach (var details in Model.ListCart)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start px-0">
                            <div>
                                <h3 class="h6 mb-1">@details.Product.Title</h3>
                                <small class="text-muted">Quantity: @details.Count</small>
                            </div>
                            <strong>@usd(details.Price * details.Count)</strong>
                        </li>
                    }
                    <li class="list-group-item d-flex justify-content-between px-0">
                        <span class="fw-bold">Total (USD)</span>
                        <strong class="h5 mb-0">@usd(Model.OrderHeader.OrderTotal)</strong>
                    </li>
                </ul>

                @if (Model.OrderHeader.ApplicationUser?.CompanyId.GetValueOrDefault() == 0 &&
                    string.Equals(Environment.EnvironmentName, "Development", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(Configuration["Stripe:EnableLocalCheckoutFallback"], "true", StringComparison.OrdinalIgnoreCase) &&
                    string.IsNullOrWhiteSpace(Configuration["Stripe:SecretKey"]))
                {
                    <div class="alert alert-info py-2 small">
                        Local checkout fallback is enabled because Stripe is not configured.
                    </div>
                }

                <p class="text-muted small mb-3">
                    Estimated arrival: @DateTime.Now.AddDays(7).ToShortDateString() - @DateTime.Now.AddDays(14).ToShortDateString()
                </p>
                <button type="submit" value="Place Order" class="btn btn-primary w-100">Place Order</button>
            </aside>
        </div>
    </div>
</form>
