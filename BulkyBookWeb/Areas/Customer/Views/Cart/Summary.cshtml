@model BulkyBook.Models.ViewModels.ShoppingCartVM
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Globalization
@{
    var usdCulture = CultureInfo.GetCultureInfo("en-US");
    Func<double, string> usd = value => value.ToString("C", usdCulture);
    var checkoutItemCount = Model.ListCart.Sum(item => item.Count);
    var stripeSecretKey = Configuration["Stripe:SecretKey"]?.Trim();
    var hasStripeApiKey = !string.IsNullOrWhiteSpace(stripeSecretKey) &&
        (stripeSecretKey.StartsWith("sk_test_", StringComparison.Ordinal) ||
            stripeSecretKey.StartsWith("sk_live_", StringComparison.Ordinal));
    var isDemoCheckoutFallbackEnabled = string.Equals(
        Configuration["Stripe:EnableLocalCheckoutFallback"],
        "true",
        StringComparison.OrdinalIgnoreCase);
}

<form method="post" class="checkout-shell checkout-page-shell mt-4">
    @Html.AntiForgeryToken()
    <div class="bb-panel checkout-panel">
        <div class="bb-panel-header checkout-panel-header">
            <div>
                <p class="cart-step-label mb-2">Step 2 of 3</p>
                <h1 class="bb-panel-title checkout-page-title">Shipping & Summary</h1>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary cart-secondary-action">Back to Cart</a>
        </div>

        <div class="checkout-grid checkout-grid-modern">
            <section class="checkout-section checkout-shipping-panel">
                <div class="checkout-section-header">
                    <span>Delivery profile</span>
                    <h2>Shipping details</h2>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="OrderHeader.Name" class="form-label">Name</label>
                        <input asp-for="OrderHeader.Name" class="form-control" />
                        <span asp-validation-for="OrderHeader.Name" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.PhoneNumber" class="form-label">Phone</label>
                        <input asp-for="OrderHeader.PhoneNumber" class="form-control" />
                        <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.PostalCode" class="form-label">Postal Code</label>
                        <input asp-for="OrderHeader.PostalCode" class="form-control" />
                        <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="OrderHeader.StreetAddress" class="form-label">Street Address</label>
                        <input asp-for="OrderHeader.StreetAddress" class="form-control" />
                        <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.City" class="form-label">City</label>
                        <input asp-for="OrderHeader.City" class="form-control" />
                        <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="OrderHeader.State" class="form-label">State</label>
                        <input asp-for="OrderHeader.State" class="form-control" />
                        <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <aside class="checkout-summary-panel">
                <div class="checkout-section-header">
                    <span>@checkoutItemCount item@(checkoutItemCount == 1 ? "" : "s")</span>
                    <h2>Order summary</h2>
                </div>
                <div class="checkout-summary-list">
                    @foreach (var details in Model.ListCart)
                    {
                        <div class="checkout-summary-item">
                            <div>
                                <h3>@details.Product.Title</h3>
                                <small>Quantity: @details.Count</small>
                            </div>
                            <strong>@usd(details.Price * details.Count)</strong>
                        </div>
                    }
                </div>

                <div class="checkout-total-row">
                    <span>Total (USD)</span>
                    <strong>@usd(Model.OrderHeader.OrderTotal)</strong>
                </div>

                @if (Model.OrderHeader.ApplicationUser?.CompanyId.GetValueOrDefault() == 0 &&
                    isDemoCheckoutFallbackEnabled &&
                    !hasStripeApiKey)
                {
                    <div class="alert alert-info checkout-fallback-alert">
                        Online card payment is currently unavailable. You can still place the order for review.
                    </div>
                }

                <p class="checkout-arrival-note">
                    Estimated arrival: @DateTime.Now.AddDays(7).ToShortDateString() - @DateTime.Now.AddDays(14).ToShortDateString()
                </p>
                <button type="submit" value="Place Order" class="btn btn-primary checkout-place-order">Place Order</button>
            </aside>
        </div>
    </div>
</form>
