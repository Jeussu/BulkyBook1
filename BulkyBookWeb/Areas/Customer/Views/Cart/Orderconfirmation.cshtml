@model int

<section class="confirmation-shell confirmation-shell--customer mt-4">
    <div class="confirmation-panel">
        <div class="confirmation-icon confirmation-icon--success" aria-hidden="true">
            <i class="bi bi-check-lg"></i>
        </div>

        <p class="confirmation-kicker">Order confirmed</p>
        <h1 class="confirmation-title">Order Placed Successfully!</h1>
        <p class="confirmation-message">
            Your order has been placed successfully. We have recorded the order and will process it through the existing checkout workflow.
        </p>

        <div class="confirmation-order">
            <span>Order Number</span>
            <strong>@Model</strong>
        </div>
    </div>
</section>

