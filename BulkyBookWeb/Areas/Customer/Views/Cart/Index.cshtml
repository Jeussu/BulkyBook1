@model BulkyBook.Models.ViewModels.ShoppingCartVM
@using BulkyBook.Utility
@using System.Globalization
@{
    var usdCulture = CultureInfo.GetCultureInfo("en-US");
    Func<double, string> usd = value => value.ToString("C", usdCulture);
}

<div class="cart-shell mt-4">
    <div class="bb-panel">
        <div class="bb-panel-header">
            <div>
                <p class="text-uppercase small text-muted fw-bold mb-1">Step 1 of 3</p>
                <h1 class="h3 bb-panel-title">Shopping Cart</h1>
            </div>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Continue Shopping</a>
        </div>

        <div class="p-4">
            @if (!Model.ListCart.Any())
            {
                <div class="empty-state mb-0">
                    <h5>Your cart is empty</h5>
                    <p>Add a book from the catalog to continue checkout.</p>
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary">Browse Books</a>
                </div>
            }
            else
            {
                @foreach (var item in Model.ListCart)
                {
                    <div class="cart-item">
                        <img src="@item.Product.ImageUrl" class="cart-cover" alt="@item.Product.Title" />
                        <div class="cart-item-main">
                            <h2 class="h5 mb-1">@item.Product.Title</h2>
                            <p class="cart-description mb-2">@Html.Raw(SafeHtml.Sanitize(item.Product.Description))</p>
                            <div class="cart-price-line">
                                <strong>@usd(item.Price)</strong>
                                <span class="mx-1">x</span>
                                <span>@item.Count</span>
                            </div>
                        </div>
                        <div class="cart-actions">
                            <div class="cart-item-total">@usd(item.Price * item.Count)</div>
                            <div class="qty-control-group" aria-label="Quantity controls">
                                <form method="post" asp-action="Minus" asp-route-cartId="@item.Id">
                                    <button type="submit" class="btn btn-qty" title="Decrease quantity">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>
                                </form>
                                <span class="qty-count">@item.Count</span>
                                <form method="post" asp-action="Plus" asp-route-cartId="@item.Id">
                                    <button type="submit" class="btn btn-qty" title="Increase quantity">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </form>
                                <form method="post" asp-action="Remove" asp-route-cartId="@item.Id">
                                    <button type="submit" class="btn btn-remove" title="Remove book">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }

                <div class="row justify-content-end mt-4">
                    <div class="col-12 col-md-5 col-lg-4">
                        <div class="cart-total">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Total (USD)</span>
                                <strong class="h4 mb-0">@usd(Model.OrderHeader.OrderTotal)</strong>
                            </div>
                            <a asp-action="Summary" class="btn btn-success w-100 mt-3">Continue to Summary</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
